---
import Container from '../ui/Container.astro';
---

<section class="hero section">
  <Container>
    <div class="hero__content">
      <p class="eyebrow">LLC Site</p>
      <h1 id="company-name">Example LLC</h1>
      <p id="hero-tagline" class="hero__tagline">
        Cloud architecture and delivery for small teams.
      </p>
      <p id="hero-description" class="hero__description">
        Example LLC helps organizations build reliable, maintainable cloud infrastructure with a strong focus on simplicity and documentation.
      </p>
    </div>
  </Container>
</section>